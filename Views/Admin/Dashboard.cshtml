@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <div class="fs-1 fw-bold">@ViewBag.TotalTrains</div>
                    <div>Total Trains</div>
                </div>
                <div class="fs-1 opacity-50"><i class="bi bi-train-front"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <div class="fs-1 fw-bold">@ViewBag.TotalBookings</div>
                    <div>Total Bookings</div>
                </div>
                <div class="fs-1 opacity-50"><i class="bi bi-ticket-perforated"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <div class="fs-1 fw-bold">@ViewBag.TotalUsers</div>
                    <div>Registered Users</div>
                </div>
                <div class="fs-1 opacity-50"><i class="bi bi-people"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center p-4">
                <div>
                    <div class="fs-4 fw-bold">₹@String.Format("{0:N0}", ViewBag.TotalRevenue)</div>
                    <div>Total Revenue</div>
                </div>
                <div class="fs-1 opacity-50"><i class="bi bi-currency-rupee"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex gap-2 flex-wrap">
    @* FIXED: Add Train button now works — points to CreateTrain action *@
    <a asp-action="CreateTrain" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Train
    </a>
    <a asp-action="AllBookings" class="btn btn-outline-success">
        <i class="bi bi-list-ul me-1"></i>View All Bookings
    </a>
    <a asp-controller="Train" asp-action="Search" class="btn btn-outline-secondary">
        <i class="bi bi-search me-1"></i>Search Trains
    </a>
</div>
