@model List<TrainTicketManagement.Models.Train>
@{
    ViewData["Title"] = "Manage Trains";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-train-front me-2"></i>Manage Trains</h2>
    <a asp-action="CreateTrain" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add New Train
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="fs-1 text-muted"><i class="bi bi-train-front"></i></div>
        <h5 class="mt-3 text-muted">No trains found.</h5>
        <a asp-action="CreateTrain" class="btn btn-primary mt-3">Add First Train</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Train Name</th>
                    <th>Number</th>
                    <th>Route</th>
                    <th>Total Seats</th>
                    <th>Price/Seat</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int sn = 1; }
                @foreach (var train in Model)
                {
                    <tr>
                        <td>@sn++</td>
                        <td class="fw-bold">@train.TrainName</td>
                        <td><span class="badge bg-secondary">#@train.TrainNumber</span></td>
                        <td>
                            <span class="text-primary">@train.FromStation?.Name</span>
                            <i class="bi bi-arrow-right mx-1"></i>
                            <span class="text-success">@train.ToStation?.Name</span>
                        </td>
                        <td>@train.TotalSeats</td>
                        <td class="text-success fw-bold">₹@train.PricePerSeat</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <!-- Edit Button -->
                                <a asp-action="EditTrain" asp-route-id="@train.Id"
                                   class="btn btn-sm btn-outline-primary" title="Edit Train">
                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                </a>

                                <!-- Delete Button -->
                                <form asp-action="DeleteTrain" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete @train.TrainName? This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@train.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Train">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small mt-2">Total: @Model.Count train(s)</p>
}

<a asp-action="Dashboard" class="btn btn-outline-secondary mt-2">
    <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
</a>
