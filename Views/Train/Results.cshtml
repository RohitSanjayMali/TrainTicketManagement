@model TrainSearchViewModel
@{
    ViewData["Title"] = "Train Results";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-train-front me-2"></i>Available Trains</h2>
    <a asp-action="Search" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Modify Search
    </a>
</div>

@if (Model.FromStation != null)
{
    <div class="alert alert-info py-2 mb-3">
        <i class="bi bi-info-circle me-1"></i>
        Showing trains from <strong>@Model.FromStation</strong> to <strong>@Model.ToStation</strong>
        on <strong>@Model.TravelDate.ToString("dd MMM yyyy")</strong>
    </div>
}

@if (!Model.Results.Any())
{
    <div class="text-center py-5">
        <div class="fs-1 text-muted"><i class="bi bi-train-front"></i></div>
        <h5 class="mt-3 text-muted">No trains found for this route.</h5>
        <a asp-action="Search" class="btn btn-primary mt-3">Try Another Search</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var train in Model.Results)
        {
            int available = TrainService.GetAvailableSeats(train.Id);
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-5">
                                <h5 class="mb-1 text-primary">
                                    <i class="bi bi-train-front-fill me-2"></i>@train.TrainName
                                </h5>
                                <span class="badge bg-secondary">Train #@train.TrainNumber</span>
                            </div>
                            <div class="col-md-3 text-center">
                                <span class="text-muted small">Route</span><br />
                                <strong>@train.FromStation?.Name</strong>
                                <i class="bi bi-arrow-right mx-2 text-primary"></i>
                                <strong>@train.ToStation?.Name</strong>
                            </div>
                            <div class="col-md-2 text-center">
                                <span class="text-muted small">Available Seats</span><br />
                                @if (available > 20)
                                {
                                    <span class="badge bg-success fs-6">@available</span>
                                }
                                else if (available > 0)
                                {
                                    <span class="badge bg-warning text-dark fs-6">@available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Full</span>
                                }
                            </div>
                            <div class="col-md-2 text-end">
                                <div class="text-success fw-bold fs-5 mb-1">@train.PricePerSeat.ToString("C0", new System.Globalization.CultureInfo("hi-IN"))</div>
                                @if (available > 0)
                                {
                                    <a asp-controller="Booking" asp-action="Create"
                                       asp-route-trainId="@train.Id"
                                       class="btn btn-primary btn-sm">
                                        <i class="bi bi-ticket me-1"></i>Book Now
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-sm" disabled>Full</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
