@model TrainSearchViewModel
@{
    ViewData["Title"] = "Search Trains";
}

<h2 class="mb-4"><i class="bi bi-search me-2"></i>Search Trains</h2>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Search" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="FromStation" class="form-label fw-semibold">From Station</label>
                    <select asp-for="FromStation" asp-items="Model.Stations" class="form-select">
                        <option value="">-- Select Source --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="ToStation" class="form-label fw-semibold">To Station</label>
                    <select asp-for="ToStation" asp-items="Model.Stations" class="form-select">
                        <option value="">-- Select Destination --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="TravelDate" class="form-label fw-semibold">Travel Date</label>
                    <input asp-for="TravelDate" type="date" class="form-control"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
