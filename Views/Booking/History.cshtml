@model List<Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<h2 class="mb-4"><i class="bi bi-clock-history me-2"></i>My Bookings</h2>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="fs-1 text-muted"><i class="bi bi-inbox"></i></div>
        <h5 class="mt-3 text-muted">No bookings found.</h5>
        <a asp-controller="Train" asp-action="Search" class="btn btn-primary mt-3">
            <i class="bi bi-search me-1"></i>Search Trains
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>PNR</th>
                    <th>Train</th>
                    <th>Route</th>
                    <th>Date</th>
                    <th>Passengers</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td><span class="fw-bold text-primary">@b.PNR</span></td>
                        <td>
                            @b.Train.TrainName<br />
                            <small class="text-muted">#@b.Train.TrainNumber</small>
                        </td>
                        <td>
                            @b.Train.FromStation?.Name
                            <i class="bi bi-arrow-right mx-1 text-primary"></i>
                            @b.Train.ToStation?.Name
                        </td>
                        <td>@b.BookingDate.ToString("dd MMM yyyy")</td>
                        <td class="text-center">@b.TotalPassengers</td>
                        <td>₹@b.Payment?.Amount.ToString("N2")</td>
                        <td>
                            <span class="badge bg-@(b.Payment?.Status == "Confirmed" ? "success" : "secondary")">
                                @(b.Payment?.Status ?? "N/A")
                            </span>
                        </td>
                        <td class="d-flex gap-1">
                            <a asp-action="DownloadTicket" asp-route-id="@b.Id"
                               class="btn btn-sm btn-outline-primary" title="Download PDF">
                                <i class="bi bi-download"></i>
                            </a>
                            @* ADDED: Cancel button — only if booking is still Confirmed *@
                            @if (b.Payment?.Status == "Confirmed")
                            {
                                <form asp-action="Cancel" asp-route-id="@b.Id" method="post"
                                      onsubmit="return confirm('Cancel this booking?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Cancel">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
