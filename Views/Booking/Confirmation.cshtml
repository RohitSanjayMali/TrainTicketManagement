@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card border-0 shadow">
            <div class="card-header bg-success text-white text-center py-4">
                <i class="fas fa-check-circle fa-3x mb-2 d-block"></i>
                <h4 class="mb-0">🎉 Booking Successful!</h4>
            </div>
            <div class="card-body p-4 text-center">
                <p class="text-muted mb-1">Your PNR Number</p>

                <h2 class="fw-bold text-primary mb-3">@TempData["PNR"]</h2>

                <p class="text-muted small mb-4">
                    Save this PNR number to check your booking status later.
                </p>

                <div class="d-flex gap-2 justify-content-center">
                    <a asp-controller="Booking" asp-action="History" class="btn btn-outline-primary">
                        My Bookings
                    </a>
                    <a asp-controller="Train" asp-action="Search" class="btn btn-primary">
                        Book Another
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
