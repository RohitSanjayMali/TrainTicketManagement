@model Booking
@{
    ViewData["Title"] = "Booking Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0"><i class="bi bi-ticket-perforated me-2"></i>Booking Details</h5>
                <span class="badge bg-white text-success fs-6">PNR: @Model.PNR</span>
            </div>
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">TRAIN INFO</h6>
                        <p class="mb-1"><strong>@Model.Train.TrainName</strong></p>
                        <p class="mb-1 text-muted">Train No: @Model.Train.TrainNumber</p>
                        <p class="mb-0">
                            <i class="bi bi-geo-alt me-1 text-danger"></i>@Model.Train.FromStation?.Name
                            <i class="bi bi-arrow-right mx-2 text-primary"></i>
                            <i class="bi bi-geo-alt me-1 text-success"></i>@Model.Train.ToStation?.Name
                        </p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">BOOKING INFO</h6>
                        <p class="mb-1">Booking Date: <strong>@Model.BookingDate.ToString("dd MMM yyyy HH:mm")</strong></p>
                        <p class="mb-1">Total Passengers: <strong>@Model.TotalPassengers</strong></p>
                        <p class="mb-0">
                            Status:
                            <span class="badge bg-@(Model.Payment?.Status == "Confirmed" ? "success" : "warning")">
                                @(Model.Payment?.Status ?? "N/A")
                            </span>
                        </p>
                    </div>
                </div>

                <h6 class="text-muted mb-3">PASSENGERS</h6>
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Gender</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int sn = 1;}
                        @foreach (var p in Model.Passengers)
                        {
                            <tr>
                                <td>@sn++</td>
                                <td>@p.Name</td>
                                <td>@p.Age</td>
                                <td>@p.Gender</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.Payment != null)
                {
                    <div class="alert alert-light border mt-3">
                        <strong>Total Amount Paid: ₹@Model.Payment.Amount.ToString("N2")</strong>
                        &nbsp;&nbsp;|&nbsp;&nbsp;
                        Method: @Model.Payment.PaymentMethod
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="DownloadTicket" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-download me-1"></i>Download PDF
                    </a>
                    <a asp-action="PNRStatus" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
